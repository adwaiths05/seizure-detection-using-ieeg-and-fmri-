# SOZ_GAT Backend — Environment Variables
# Copy to .env and fill in values

HOST=0.0.0.0
PORT=8000
DEBUG=false

MODEL_PATH=saved_models/soz_gat.pt
SCALER_PATH=saved_models/scaler.pkl
MODEL_VERSION=1.0.0

DEVICE=cpu
# DEVICE=cuda  # uncomment if GPU available

RATE_LIMIT=60
# Comma-separated origins for local Next.js (pnpm dev). Use * only if you widen CORS policy deliberately.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
# CORS_ORIGINS=*

API_KEY_ENABLED=false
# API_KEY=your-secret-key-here

LOG_LEVEL=INFO
LOG_DIR=logs
